{
  "expo": {
    "name": "Mediatools",
    "slug": "mediatools",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mediatools",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.tukozy.mediatools"
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio/app.plugin",
        {
          "microphonePermission": "Izinkan Media Tools mengakses mikrofon untuk merekam audio & voice-over."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan Media Tools mengakses kamera untuk rekam konten dan scan QR.",
          "microphonePermission": "Izinkan Media Tools mengakses mikrofon untuk merekam audio & voice-over."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/media-tools.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Izinkan Media Tools mengakses galeri untuk menyimpan hasil download dan memilih media.",
          "savePhotosPermission": "Izinkan Media Tools menyimpan file ke galeri.",
          "granularPermissions": ["photo", "video"]
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "tukozy",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cd3101a8-5da0-4ad0-9039-ef55fc9c60b4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cd3101a8-5da0-4ad0-9039-ef55fc9c60b4"
    }
  }
}
